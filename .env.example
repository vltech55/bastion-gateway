# ---- Upstream provider credentials ----
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Bedrock requires both AWS_* and a deployed model ARN; empty = Bedrock adapter falls back to the next provider in the chain.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_CLAUDE_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ---- Database ----
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway
POSTGRES_DB=gateway
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://gateway:gateway@postgres:5432/gateway

# ---- Redis (cache + rate limit) ----
REDIS_URL=redis://redis:6379/0

# ---- Gateway tuning ----
GATEWAY_API_KEYS=demo-key-please-rotate
CACHE_TTL_SECONDS=86400
CACHE_TEMP_THRESHOLD=0.0    # cache responses with temperature <= this value
RATE_LIMIT_TOKENS=120
RATE_LIMIT_REFILL_PER_SEC=2.0
CIRCUIT_BREAKER_FAILURES=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# ---- HTTP ----
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO
